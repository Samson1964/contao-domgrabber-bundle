{
    "name": "schachbulle/contao-domgrabber-bundle",
    "type": "contao-bundle",
    "description": "DOM-Grabber für Contao 5",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Frank Binding",
            "homepage": "https://www.schachbulle.de/"
        }
    ],
    "require": {
        "php": "^8.3",
        "contao/core-bundle": "^5.3",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/cache": "^6.4 || ^7.0",
        "axllent/simplehtmldom": "^1.6"
    },
    "conflict": {
        "contao/core": "*",
        "contao/manager-plugin": "<2.0 || >=3.0"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.0"
    },
    "extra": {
        "contao-manager-plugin": "Schachbulle\\ContaoDomgrabberBundle\\ContaoManager\\Plugin"
    },
    "autoload": {
        "psr-4": {
            "Schachbulle\\ContaoDomgrabberBundle\\": "src/"
        }
    },
    "support": {
        "issues": "https://github.com/Samson1964/contao-domgrabber-bundle/issues",
        "source": "https://github.com/Samson1964/contao-domgrabber-bundle"
    }
}
